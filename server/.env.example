# Copy this file to server/.env and fill in your key.
# server/.env is gitignored — NEVER commit the real key.

ANTHROPIC_API_KEY=sk-ant-...

PORT=5201
WEB_ORIGIN=http://localhost:5200

# Models (swappable). Chat favours responsiveness; plan can use Opus for depth.
MODEL_CHAT=claude-sonnet-4-6
MODEL_GENERATE=claude-sonnet-4-6
MODEL_PLAN=claude-sonnet-4-6

# Reasoning effort for the chat surface: low | medium | high  (max is Opus-only)
CHAT_EFFORT=medium
